+  gap: 4px;
+  font-size: 0.72rem;
+  font-weight: 600;
+  color: #71717a;
+}
+
+.busca-card-specs svg { width: 11px; height: 11px; flex-shrink: 0; }
+
+.busca-card-price {
+  font-family: var(--display);
+  font-size: 1.3rem;
+  font-weight: 900;
+  letter-spacing: -0.03em;
+  color: var(--lime-bright);
+}
+
+.busca-card-actions {
+  display: grid;
+  grid-template-columns: 1fr auto;
+  gap: 8px;
+}
+
+.busca-btn-interest {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 6px;
+  padding: 10px 14px;
+  border-radius: 9px;
+  background: var(--lime);
+  color: var(--ink);
+  font-family: var(--display);
+  font-size: 0.72rem;
+  font-weight: 900;
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+  transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
+}
+
+.busca-btn-interest svg { width: 13px; height: 13px; }
+.busca-btn-interest:hover {
+  background: var(--lime-bright);
+  transform: translateY(-2px);
+  box-shadow: 0 8px 20px rgba(134, 225, 0, 0.35);
+}
+
+.busca-btn-detail {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  padding: 10px 14px;
+  border: 1px solid rgba(255,255,255,0.12);
+  border-radius: 9px;
+  background: transparent;
+  font: inherit;
+  font-size: 0.72rem;
+  font-weight: 700;
+  color: #a1a1aa;
+  cursor: pointer;
+  white-space: nowrap;
+  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
+}
+
+.busca-btn-detail:hover {
+  border-color: rgba(255,255,255,0.3);
+  color: #fff;
+  background: rgba(255,255,255,0.06);
+}
+
+/* ── Empty state ─────────────────────────────── */
+.busca-empty {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 14px;
+  padding: 60px 20px;
+  text-align: center;
+  color: #52525b;
+}
+
+.busca-empty svg { width: 48px; height: 48px; opacity: 0.3; }
+.busca-empty p { margin: 0; font-size: 1rem; font-weight: 500; color: #71717a; }
+
+.busca-empty button {
+  padding: 10px 22px;
+  border: 1px solid rgba(255,255,255,0.12);
+  border-radius: 8px;
+  background: rgba(255,255,255,0.04);
+  font: inherit;
+  font-size: 0.85rem;
+  font-weight: 700;
+  color: #fff;
+  cursor: pointer;
+  transition: background 0.15s;
+}
+
+.busca-empty button:hover { background: rgba(255,255,255,0.08); }
+
+/* ── Responsive ──────────────────────────────── */
+@media (max-width: 1100px) {
+  .busca-grid { grid-template-columns: repeat(2, 1fr); }
+}
+
+@media (max-width: 860px) {
+  .busca-layout { grid-template-columns: 1fr; }
+
+  .busca-sidebar {
+    position: fixed;
+    inset: 0 auto 0 0;
+    width: 300px;
+    top: 0;
+    z-index: 200;
+    border-radius: 0;
+    overflow-y: auto;
+    transform: translateX(-100%);
+    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
+    box-shadow: 4px 0 32px rgba(0,0,0,0.12);
+  }
+
+  .busca-sidebar.is-open { transform: translateX(0); }
+
+  .busca-filter-toggle { display: inline-flex; }
+}
+
+@media (max-width: 560px) {
+  .busca-grid { grid-template-columns: 1fr; }
+  .busca-card-actions { grid-template-columns: 1fr; }
+}
