+++ b/busca.js
@@ -0,0 +1,294 @@
+let vehicles = [];
+
+const MOTO_MODELS = ["PCX", "BIZ", "CG", "TITAN", "FAN", "BROS", "POP", "NXR", "CB", "YBR", "FACTOR"];
+
+function getTipo(vehicle) {
+  return MOTO_MODELS.some((m) => vehicle.model.toUpperCase().includes(m)) ? "Moto" : "Automóvel";
+}
+
+function priceNum(vehicle) {
+  if (!vehicle.price || vehicle.price.toLowerCase().includes("consulte")) return Infinity;
+  return parseFloat(vehicle.price.replace(/[^\d,]/g, "").replace(",", ".")) || Infinity;
+}
+
+const state = {
+  text: "",
+  tipo: new Set(),
+  marca: new Set(),
+  anoMin: "",
+  anoMax: "",
+  combustivel: new Set(),
+  cambio: new Set(),
+  cor: new Set(),
+  sort: "default",
+};
+
+function getFiltered() {
+  let list = [...vehicles];
+
+  if (state.text) {
+    const q = state.text.toLowerCase();
+    list = list.filter((v) =>
+      [v.make, v.model, v.year, v.fuel, v.transmission, v.color].join(" ").toLowerCase().includes(q)
+    );
+  }
+  if (state.tipo.size) list = list.filter((v) => state.tipo.has(getTipo(v)));
+  if (state.marca.size) list = list.filter((v) => state.marca.has(v.make));
+  if (state.anoMin) list = list.filter((v) => parseInt(v.year) >= parseInt(state.anoMin));
+  if (state.anoMax) list = list.filter((v) => parseInt(v.year) <= parseInt(state.anoMax));
+  if (state.combustivel.size) list = list.filter((v) => state.combustivel.has(v.fuel));
+  if (state.cambio.size) list = list.filter((v) => state.cambio.has(v.transmission));
+  if (state.cor.size) list = list.filter((v) => v.color && state.cor.has(v.color));
+
+  switch (state.sort) {
+    case "price-asc":  list.sort((a, b) => priceNum(a) - priceNum(b)); break;
+    case "price-desc": list.sort((a, b) => priceNum(b) - priceNum(a)); break;
+    case "year-desc":  list.sort((a, b) => parseInt(b.year) - parseInt(a.year)); break;
+    case "year-asc":   list.sort((a, b) => parseInt(a.year) - parseInt(b.year)); break;
+    case "az":         list.sort((a, b) => `${a.make} ${a.model}`.localeCompare(`${b.make} ${b.model}`)); break;
+    case "za":         list.sort((a, b) => `${b.make} ${b.model}`.localeCompare(`${a.make} ${a.model}`)); break;
+  }
+
+  return list;
+}
+
+function buscaCard(vehicle, index) {
+  const text = encodeURIComponent(`${vehicle.make} ${vehicle.model} ${vehicle.year}`);
+  const tipo = getTipo(vehicle);
+  const img = vehicle.image
+    ? `<img src="${vehicle.image}" alt="${vehicle.make} ${vehicle.model}" loading="lazy" />`
+    : `<div class="busca-card-placeholder"><span>Henrique</span><small>Veículos</small></div>`;
+
+  return `
+    <article class="busca-card reveal">
+      <div class="busca-card-media" style="--card-bg:${vehicle.bg}">
+        ${img}
+        <span class="busca-card-year">${vehicle.year}</span>
+        <span class="busca-card-tipo">${tipo}</span>
+      </div>
+      <div class="busca-card-body">
+        <span class="busca-card-make">${vehicle.make}</span>
+        <h3 class="busca-card-model">${vehicle.model}</h3>
+        <div class="busca-card-specs">
+          ${vehicle.km ? `<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>${vehicle.km} km</span>` : ""}
+          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4"/><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>${vehicle.fuel}</span>
+          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>${vehicle.transmission}</span>
+          ${vehicle.color ? `<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>${vehicle.color}</span>` : ""}
+        </div>
+        <div class="busca-card-price">${vehicle.price}</div>
+        <div class="busca-card-actions">
+          <a class="busca-btn-interest" href="${whatsappBase}${text}" target="_blank" rel="noreferrer">
+            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4.2a7.6 7.6 0 0 0-6.5 11.5L4.7 20l4.4-1.1A7.6 7.6 0 1 0 12 4.2Z"/></svg>
+            Estou interessado
+          </a>
+          <button type="button" class="busca-btn-detail open-detail" data-vehicle-index="${vehicles.indexOf(vehicle)}">
+            Ver detalhes →
+          </button>
+        </div>
+      </div>
+    </article>
+  `;
+}
+
+function buildCheckList(containerId, values, stateKey) {
+  const el = document.getElementById(containerId);
+  if (!el) return;
+  el.innerHTML = [...values].sort().map((val) => `
+    <label class="filter-check">
+      <input type="checkbox" value="${val}" data-filter="${stateKey}" />
+      <span class="filter-check-box"></span>
+      <span class="filter-check-label">${val}</span>
+    </label>
+  `).join("");
+}
+
+function renderActiveTags() {
+  const container = document.getElementById("busca-active-tags");
+  if (!container) return;
+  const tags = [];
+
+  if (state.text) tags.push({ label: `"${state.text}"`, key: "text" });
+  state.tipo.forEach((v) => tags.push({ label: v, key: "tipo", val: v }));
+  state.marca.forEach((v) => tags.push({ label: v, key: "marca", val: v }));
+  if (state.anoMin || state.anoMax) tags.push({ label: `Ano: ${state.anoMin || "…"} — ${state.anoMax || "…"}`, key: "ano" });
+  state.combustivel.forEach((v) => tags.push({ label: v, key: "combustivel", val: v }));
+  state.cambio.forEach((v) => tags.push({ label: v, key: "cambio", val: v }));
+  state.cor.forEach((v) => tags.push({ label: v, key: "cor", val: v }));
+
+  container.innerHTML = tags.map((t) => `
+    <button class="busca-tag" type="button" data-tag-key="${t.key}" data-tag-val="${t.val || ""}">
+      ${t.label} <span aria-hidden="true">×</span>
+    </button>
+  `).join("");
+}
+
+function render() {
+  const list = getFiltered();
+  const grid = document.getElementById("busca-grid");
+  const empty = document.getElementById("busca-empty");
+  const count = document.getElementById("busca-result-count");
+
+  if (!grid) return;
+
+  if (!list.length) {
+    grid.innerHTML = "";
+    empty.hidden = false;
+  } else {
+    empty.hidden = true;
+    grid.innerHTML = list.map((v) => buscaCard(v, vehicles.indexOf(v))).join("");
+  }
+
+  if (count) {
+    count.innerHTML = list.length
+      ? `<strong>${list.length}</strong> ${list.length === 1 ? "veículo encontrado" : "veículos encontrados"}`
+      : "Nenhum resultado";
+  }
+
+  renderActiveTags();
+}
+
+function init() {
+  const makes = new Set(vehicles.map((v) => v.make).filter(Boolean));
+  const fuels = new Set(vehicles.map((v) => v.fuel).filter(Boolean));
+  const cambios = new Set(vehicles.map((v) => v.transmission).filter(Boolean));
+  const cores = new Set(vehicles.map((v) => v.color).filter(Boolean));
+  const tipos = new Set(vehicles.map(getTipo));
+
+  buildCheckList("filter-tipo", tipos, "tipo");
+  buildCheckList("filter-marca", makes, "marca");
+  buildCheckList("filter-combustivel", fuels, "combustivel");
+  buildCheckList("filter-cambio", cambios, "cambio");
+  buildCheckList("filter-cor", cores, "cor");
+
+  // Text search
+  const textInput = document.getElementById("busca-text");
+  if (textInput) {
+    textInput.addEventListener("input", (e) => {
+      state.text = e.target.value.trim();
+      render();
+    });
+  }
+
+  // Header search form
+  const headerForm = document.getElementById("busca-header-form");
+  const headerInput = document.getElementById("busca-header-input");
+  if (headerForm && headerInput && textInput) {
+    headerForm.addEventListener("submit", (e) => {
+      e.preventDefault();
+      textInput.value = headerInput.value.trim();
+      state.text = textInput.value;
+      render();
+    });
+  }
+
+  // Checkboxes
+  document.getElementById("busca-sidebar").addEventListener("change", (e) => {
+    const cb = e.target;
+    if (cb.type !== "checkbox") return;
+    const key = cb.dataset.filter;
+    if (!key || !state[key]) return;
+    cb.checked ? state[key].add(cb.value) : state[key].delete(cb.value);
+    render();
+  });
+
+  // Ano range
+  ["ano-min", "ano-max"].forEach((id) => {
+    const el = document.getElementById(id);
+    if (!el) return;
+    el.addEventListener("input", () => {
+      state.anoMin = document.getElementById("ano-min").value;
+      state.anoMax = document.getElementById("ano-max").value;
+      render();
+    });
+  });
+
+  // Sort
+  const sortEl = document.getElementById("busca-sort");
+  if (sortEl) {
+    sortEl.addEventListener("change", () => {
+      state.sort = sortEl.value;
+      render();
+    });
+  }
+
+  // Clear all
+  function clearAll() {
+    state.text = "";
+    state.tipo.clear();
+    state.marca.clear();
+    state.anoMin = "";
+    state.anoMax = "";
+    state.combustivel.clear();
+    state.cambio.clear();
+    state.cor.clear();
+
+    document.querySelectorAll("#busca-sidebar input[type=checkbox]").forEach((cb) => (cb.checked = false));
+    document.querySelectorAll(".filter-range-input").forEach((el) => (el.value = ""));
+    const t = document.getElementById("busca-text");
+    if (t) t.value = "";
+    render();
+  }
+
+  document.getElementById("clear-filters")?.addEventListener("click", clearAll);
+  document.getElementById("empty-clear")?.addEventListener("click", clearAll);
+
+  // Active tags click
+  document.getElementById("busca-active-tags").addEventListener("click", (e) => {
+    const btn = e.target.closest(".busca-tag");
+    if (!btn) return;
+    const key = btn.dataset.tagKey;
+    const val = btn.dataset.tagVal;
+
+    if (key === "text") { state.text = ""; const t = document.getElementById("busca-text"); if (t) t.value = ""; }
+    else if (key === "ano") { state.anoMin = ""; state.anoMax = ""; document.querySelectorAll(".filter-range-input").forEach((el) => (el.value = "")); }
+    else if (state[key]) {
+      state[key].delete(val);
+      const cb = document.querySelector(`input[data-filter="${key}"][value="${val}"]`);
+      if (cb) cb.checked = false;
+    }
+    render();
+  });
+
+  // Mobile filter toggle
+  const toggle = document.getElementById("busca-filter-toggle");
+  const sidebar = document.getElementById("busca-sidebar");
+  if (toggle && sidebar) {
+    toggle.addEventListener("click", () => {
+      const isOpen = sidebar.classList.toggle("is-open");
+      toggle.setAttribute("aria-expanded", String(isOpen));
+    });
+  }
+
+  // Header menu mobile
+  const menuButton = document.querySelector(".menu-button");
+  const menu = document.querySelector("#site-menu");
+  if (menuButton && menu) {
+    menuButton.addEventListener("click", () => {
+      const isOpen = menu.classList.toggle("is-open");
+      menuButton.setAttribute("aria-expanded", String(isOpen));
+    });
+  }
+
+  // Check URL param ?q=
+  const params = new URLSearchParams(window.location.search);
+  const q = params.get("q");
+  if (q) {
+    state.text = q;
+    const t = document.getElementById("busca-text");
+    if (t) t.value = q;
+  }
+
+  render();
+}
+
+async function loadAndInit() {
+  try {
+    const res = await fetch("./veiculos.json");
+    vehicles = await res.json();
+  } catch {
+    vehicles = [];
+  }
+  init();
+}
+
+loadAndInit();
