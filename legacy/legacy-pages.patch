+  color: #d4d4d8;
+  font-size: 0.84rem;
+  font-weight: 700;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.cons-brand-list li:last-child {
+  border-bottom: 0;
+}
+
+.cons-mini-form {
+  display: grid;
+  gap: 10px;
+}
+
+.cons-mini-form button {
+  width: 100%;
+}
+
+.cons-side-note {
+  display: grid;
+  gap: 12px;
+}
+
+.cons-side-note a {
+  width: 100%;
+  text-decoration: none;
+}
+
+.cons-submit button {
+  padding-inline: 30px;
+}
+
+.cons-mini-form button,
+.cons-side-note a {
+  min-height: 50px;
+}
+
+@media (min-width: 980px) {
+  .cons-hero-grid,
+  .cons-layout {
+    grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
+    align-items: start;
+  }
+
+  .cons-sidebar {
+    position: sticky;
+    top: 128px;
+  }
+
+  .cons-half {
+    grid-column: span 1;
+  }
+}
+
+@media (max-width: 760px) {
+  .cons-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .cons-half,
+  .cons-full {
+    grid-column: span 1;
+  }
+
+  .cons-inline {
+    grid-template-columns: 90px minmax(0, 1fr);
+  }
+}
+
+@media (max-width: 520px) {
+  .cons-hero h1,
+  .cons-section-head h2 {
+    font-size: clamp(2rem, 10vw, 2.8rem);
+  }
