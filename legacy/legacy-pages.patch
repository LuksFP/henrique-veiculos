+
+.cons-field textarea {
+  min-height: 120px;
+  resize: vertical;
+}
+
+.cons-inline {
+  display: grid;
+  grid-template-columns: 110px minmax(0, 1fr);
+  gap: 10px;
+}
+
+.cons-check {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+}
+
+.cons-check input {
+  width: 16px;
+  height: 16px;
