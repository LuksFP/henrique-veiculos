+/* ── Page ────────────────────────────────────── */
+.emp-page {
+  min-height: 100vh;
+  background:
+    radial-gradient(circle at 10% 0%, rgba(134, 225, 0, 0.09), transparent 32rem),
+    radial-gradient(circle at 90% 60%, rgba(134, 225, 0, 0.04), transparent 28rem),
+    #050505;
+  color: #fff;
+}
+
+/* ── Shared utilities ────────────────────────── */
+.emp-eyebrow,
+.emp-section-tag {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  font-family: var(--display);
+  font-size: 0.72rem;
+  font-weight: 900;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: var(--lime-bright);
+}
+
+.emp-eyebrow::before,
+.emp-section-tag::before {
+  content: "";
+  display: inline-block;
+  width: 24px;
+  height: 2px;
+  background: var(--lime-bright);
+  border-radius: 2px;
+}
+
+/* ── Hero ────────────────────────────────────── */
+.emp-hero {
+  padding: 72px 0 64px;
+  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
+}
+
+.emp-hero-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 48px;
+  flex-wrap: wrap;
+}
+
+.emp-hero-copy {
+  display: grid;
+  gap: 20px;
+  max-width: 560px;
+}
+
+.emp-title {
+  font-family: var(--display);
+  font-size: clamp(2.2rem, 5vw, 3.6rem);
+  font-weight: 900;
+  line-height: 1.05;
+  margin: 0;
+  color: #fff;
+}
+
+.emp-title-accent {
+  color: var(--lime-bright);
+}
+
+.emp-subtitle {
+  font-size: 1.05rem;
+  line-height: 1.65;
+  color: rgba(255,255,255,0.65);
+  margin: 0;
+}
+
+.emp-hero-stats {
+  display: flex;
+  gap: 32px;
+  flex-wrap: wrap;
+}
+
+.emp-stat {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  padding: 20px 28px;
+  background: rgba(255,255,255,0.04);
+  border: 1px solid rgba(255,255,255,0.08);
+  border-radius: 14px;
+  min-width: 120px;
+  text-align: center;
+}
+
+.emp-stat strong {
+  font-family: var(--display);
+  font-size: 1.8rem;
+  font-weight: 900;
+  color: var(--lime-bright);
+  line-height: 1;
+}
+
+.emp-stat span {
+  font-size: 0.78rem;
+  color: rgba(255,255,255,0.5);
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  font-weight: 600;
+}
+
+/* ── About ───────────────────────────────────── */
+.emp-about {
+  padding: 80px 0;
+  border-bottom: 1px solid rgba(255,255,255,0.06);
+}
+
+.emp-about-grid {
+  display: grid;
+  grid-template-columns: 1fr 380px;
+  gap: 64px;
+  align-items: start;
+}
+
+.emp-about-copy {
+  display: grid;
+  gap: 20px;
+}
+
+.emp-about-copy h2 {
+  font-family: var(--display);
+  font-size: clamp(1.6rem, 3vw, 2.2rem);
+  font-weight: 800;
+  line-height: 1.15;
+  margin: 0;
+  color: #fff;
+}
+
+.emp-about-copy p {
+  font-size: 1rem;
+  line-height: 1.7;
+  color: rgba(255,255,255,0.6);
+  margin: 0;
+}
+
+.emp-about-card {
+  background: rgba(255,255,255,0.04);
+  border: 1px solid rgba(255,255,255,0.08);
+  border-radius: 18px;
+  padding: 32px;
+  display: grid;
+  gap: 28px;
+}
+
+.emp-about-logo {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+}
+
+.emp-about-logo .logo-script {
+  font-family: var(--script);
+  font-size: 2rem;
+  color: var(--lime-bright);
+  line-height: 1;
+}
+
+.emp-about-logo .logo-sub {
+  font-family: var(--display);
+  font-size: 0.8rem;
+  font-weight: 700;
+  letter-spacing: 0.2em;
+  text-transform: uppercase;
+  color: rgba(255,255,255,0.5);
+}
+
+.emp-about-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 12px;
+}
+
+.emp-about-list li {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  font-size: 0.92rem;
+  color: rgba(255,255,255,0.75);
+}
+
+.emp-about-list svg {
+  width: 16px;
+  height: 16px;
+  flex-shrink: 0;
+  stroke: var(--lime-bright);
+}
+
+/* ── Values ──────────────────────────────────── */
+.emp-values {
+  padding: 80px 0;
+  border-bottom: 1px solid rgba(255,255,255,0.06);
+}
+
+.emp-values .wrap {
+  display: grid;
+  gap: 40px;
+}
+
+.emp-values h2 {
+  font-family: var(--display);
+  font-size: clamp(1.6rem, 3vw, 2.2rem);
+  font-weight: 800;
+  line-height: 1.15;
+  margin: 0;
+  color: #fff;
+  max-width: 520px;
+}
+
+.emp-values-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
+  gap: 20px;
+}
+
+.emp-value-card {
+  background: rgba(255,255,255,0.04);
+  border: 1px solid rgba(255,255,255,0.07);
+  border-radius: 16px;
+  padding: 28px;
+  display: grid;
+  gap: 14px;
+  transition: border-color 0.2s, background 0.2s;
+}
+
+.emp-value-card:hover {
+  border-color: rgba(166, 255, 26, 0.25);
+  background: rgba(166, 255, 26, 0.04);
+}
+
+.emp-value-icon {
+  width: 44px;
+  height: 44px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: rgba(166, 255, 26, 0.08);
+  border-radius: 10px;
+}
+
+.emp-value-icon svg {
+  width: 22px;
+  height: 22px;
+  stroke: var(--lime-bright);
+}
+
+.emp-value-card h3 {
+  font-family: var(--display);
+  font-size: 1rem;
+  font-weight: 700;
+  color: #fff;
+  margin: 0;
+}
+
+.emp-value-card p {
+  font-size: 0.9rem;
+  line-height: 1.6;
+  color: rgba(255,255,255,0.55);
+  margin: 0;
+}
+
+/* ── Location ────────────────────────────────── */
+.emp-location {
+  padding: 80px 0 100px;
+}
+
+.emp-location-grid {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 64px;
+  align-items: start;
+}
+
+.emp-location-copy {
+  display: grid;
+  gap: 24px;
+}
+
+.emp-location-copy h2 {
+  font-family: var(--display);
+  font-size: clamp(1.6rem, 3vw, 2.2rem);
+  font-weight: 800;
+  line-height: 1.15;
+  margin: 0;
+  color: #fff;
+}
+
+.emp-location-copy p {
+  font-size: 0.98rem;
+  line-height: 1.7;
+  color: rgba(255,255,255,0.6);
+  margin: 0;
+}
+
+.emp-location-info {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 14px;
+}
+
+.emp-location-info li {
+  display: flex;
+  align-items: flex-start;
+  gap: 12px;
+  font-size: 0.92rem;
+  color: rgba(255,255,255,0.7);
+  line-height: 1.5;
+}
+
+.emp-location-info svg {
+  width: 18px;
+  height: 18px;
+  flex-shrink: 0;
+  margin-top: 1px;
+  stroke: var(--lime-bright);
+}
+
+.emp-location-actions {
+  display: flex;
+  gap: 12px;
+  flex-wrap: wrap;
+}
+
+.emp-cta {
+  display: inline-flex;
+  align-items: center;
+  padding: 12px 24px;
+  border-radius: 10px;
+  font-family: var(--display);
+  font-size: 0.88rem;
+  font-weight: 700;
+  cursor: pointer;
+  transition: opacity 0.15s;
+  text-decoration: none;
+}
+
+.emp-cta:hover {
+  opacity: 0.85;
+}
+
+.emp-cta.primary {
+  background: var(--lime-bright);
+  color: #0a0a0a;
+}
+
+.emp-cta.ghost {
+  background: transparent;
+  color: rgba(255,255,255,0.75);
+  border: 1px solid rgba(255,255,255,0.2);
+}
+
+.emp-location-map {
+  border-radius: 18px;
+  overflow: hidden;
+  border: 1px solid rgba(255,255,255,0.08);
+}
+
+/* ── Responsive ──────────────────────────────── */
+@media (max-width: 900px) {
+  .emp-about-grid,
+  .emp-location-grid {
+    grid-template-columns: 1fr;
+    gap: 40px;
+  }
+
+  .emp-hero-inner {
+    flex-direction: column;
+    align-items: flex-start;
+  }
+
+  .emp-hero-stats {
+    width: 100%;
+  }
+
+  .emp-stat {
+    flex: 1;
+    min-width: 0;
+  }
+}
+
+@media (max-width: 480px) {
+  .emp-hero {
+    padding: 48px 0 40px;
+  }
+
+  .emp-about,
+  .emp-values,
+  .emp-location {
+    padding: 56px 0;
+  }
+
+  .emp-hero-stats {
+    gap: 12px;
+  }
+}
