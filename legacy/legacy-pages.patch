+
+  .fin-grid {
+    grid-template-columns: 1fr 1fr;
+  }
+
+  .fin-half,
+  .fin-third { grid-column: span 1; }
+  .fin-two-thirds { grid-column: span 2; }
+  .fin-full { grid-column: span 2; }
+}
+
