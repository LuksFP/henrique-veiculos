+    inset 0 -1px 0 rgba(0, 0, 0, 0.14);
+}
+
+.cons-sidebar {
+  display: grid;
+  gap: 18px;
+  align-content: start;
+}
+
+.cons-side-block {
+  padding: 22px;
+}
+
+.cons-side-block h3 {
+  margin: 0 0 14px;
+}
+
+.cons-brand-list {
